# ============================================================================
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored — never commit secrets.
# ============================================================================

# ----- Supabase ------------------------------------------------------------
# Pick ONE of the two setups below:

# A) Local Supabase (recommended for dev)
#    1. Install CLI:  npm i -g supabase  (or: scoop install supabase)
#    2. Run:          supabase start      (from this folder)
#    3. The CLI prints API URL + anon key + service role + DB URL.
#       Copy them here.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...local-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...local-service-role
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# B) Remote Supabase project (production)
#    Get from https://app.supabase.com -> Project Settings -> API
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...
# DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ----- AI providers --------------------------------------------------------
# At least ONE is required. OpenAI is the default; the others are optional.
OPENAI_API_KEY=<your-openai-api-key>
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Override the default provider (openai | anthropic | gemini)
EXTRACTION_PROVIDER=openai

# ----- Stripe (billing) ----------------------------------------------------
# 1. Create an account on https://dashboard.stripe.com
# 2. Create 3 recurring products (Pro 49 €/mo, Team 129 €/mo, Enterprise custom)
# 3. Copy the API keys + price IDs below.
# 4. Configure a webhook on https://yourdomain.com/api/billing/webhook
#    listening to: checkout.session.completed, customer.subscription.updated,
#    customer.subscription.deleted
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
STRIPE_PRICE_PRO=<your-stripe-price-id-pro>
STRIPE_PRICE_TEAM=<your-stripe-price-id-team>
# Enterprise has no price ID — it goes to a sales contact form.

# Base URL of this app (used for Stripe redirect URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Misc ----------------------------------------------------------------
LOG_LEVEL=debug
